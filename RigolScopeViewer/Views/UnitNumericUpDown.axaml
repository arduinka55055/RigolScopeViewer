<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             x:Class="RigolScopeViewer.UnitNumericUpDown">
  <Grid ColumnDefinitions="Auto,*,Auto">
    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="2">
      <Button Name="StepDownButton" Width="30" Click="StepDownButton_Click">
        <PathIcon Data="M0,0 L10,0 L5,8 Z" Width="10" Height="8" />
      </Button>
      <Button Name="StepUpButton" Width="30" Click="StepUpButton_Click">
        <PathIcon Data="M0,8 L10,8 L5,0 Z" Width="10" Height="8" />
      </Button>
    </StackPanel>

    <NumericUpDown Name="NumericBox"
                   Grid.Column="1"
                   ShowButtonSpinner="False"
                   FormatString="F3"
                   ValueChanged="NumericBox_ValueChanged"
                   LostFocus="NumericBox_LostFocus">
      <NumericUpDown.InnerRightContent>
        <ComboBox Name="UnitComboBox"
                  MinWidth="60"
                  VerticalAlignment="Stretch"
                  SelectionChanged="UnitComboBox_SelectionChanged"
                  PointerPressed="UnitComboBox_PointerPressed"/>
      </NumericUpDown.InnerRightContent>
    </NumericUpDown>
  </Grid>
</UserControl>