<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:RigolScopeViewer.ViewModels"
        xmlns:local="using:RigolScopeViewer"
        xmlns:visa="clr-namespace:RigolScopeViewer.Sources.VISA"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="RigolScopeViewer.MainWindow"
        Icon="/Assets/avalonia-logo.ico"
        Title="Rigol Oscilloscope Viewer">

  <Design.DataContext>
    <vm:MainViewModel />
  </Design.DataContext>

  <DockPanel LastChildFill="True">

    <!-- Menu -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="File">
        <MenuItem Header="Open" Command="{Binding OpenCommand}"/>
        <MenuItem Header="Capture (VISA)" Command="{Binding CaptureCommand}"/>
        <Separator />
        <MenuItem Header="Exit" Command="{Binding ExitCommand}"/>
      </MenuItem>
      <MenuItem Header="View">
        <MenuItem Header="Zoom In" Command="{Binding ZoomInCommand}"/>
        <MenuItem Header="Zoom Out" Command="{Binding ZoomOutCommand}"/>
      </MenuItem>
    </Menu>

    <!-- Toolbar -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Height="40" Background="#333">
      <Button Content="Open" Command="{Binding OpenCommand}" Margin="5"/>
      <Button Content="Capture" Command="{Binding CaptureCommand}" Margin="5"/>
      <Separator Margin="5,0" Background="#666" Width="1"/>
      <TextBlock Text="Time/div:" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="White"/>
      <local:UnitNumericUpDown VerticalAlignment="Center" Margin="15,0,0,0" Foreground="White"
                               BaseValue="{Binding TimePerDivision}"
                               UnitSymbol="s"
                               />

      <TextBlock Text="Offset:" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="White"/>
      <local:UnitNumericUpDown VerticalAlignment="Center" Margin="15,0,0,0" Foreground="White"
                               BaseValue="{Binding TimeOffset}"
                               IncrementType="Step" Step="{Binding TimePerDivision}"
                               UnitSymbol="s"
                               />


      <ContentControl Content="{Binding WaveformSource.ControlPanelViewModel}" Margin="15,0,0,0" VerticalAlignment="Center">

        <!-- Шаблон для малювання кнопок VISA -->
        <ContentControl.DataTemplates>
          <DataTemplate DataType="visa:VisaControlViewModel">
            <StackPanel Orientation="Horizontal" Spacing="5">

              <Button Command="{Binding StartCommand}"
                      IsEnabled="{Binding !IsRunning}"
                      Content="▶ Live View" />

              <Button Command="{Binding StopCommand}"
                      IsEnabled="{Binding IsRunning}"
                      Content="⏹ Stop"
                      Background="#AA0000" Foreground="White" />

              <Button Command="{Binding ResetConnectionCommand}"
                      Content="🔄 Reset" />

            </StackPanel>
          </DataTemplate>
        </ContentControl.DataTemplates>

      </ContentControl>




    </StackPanel>


    <!-- Status Bar -->
    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Height="25" Background="#333">
      <TextBlock Text="Ready" VerticalAlignment="Center" Foreground="White"/>
      <TextBlock Text=" | " VerticalAlignment="Center" Foreground="White"/>
      <TextBlock Text="{Binding TimePerDivision, StringFormat='Time/div: {0:F6} s'}"
                 VerticalAlignment="Center" Foreground="White"/>
      <TextBlock Text=" | " VerticalAlignment="Center" Foreground="White"/>
      <TextBlock Text="{Binding TimeOffset, StringFormat='Offset: {0:F6} s'}"
                 VerticalAlignment="Center" Foreground="White"/>

      <ProgressBar IsIndeterminate="True" IsVisible="{Binding IsBusy}" />
    </StackPanel>

    <!-- Main Content -->
    <Grid Background="LightGray">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="320"/>
      </Grid.ColumnDefinitions>

      <!-- Oscilloscope Display -->
      <local:OscilloscopeControl x:Name="OscilloscopeView"
                                 Grid.Column="0"
                                 Background="#111" />

      <!-- Channel Controls -->
      <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Background="#444">
        <ItemsControl ItemsSource="{Binding Channels}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Border Classes.active="{Binding IsActive}" BorderThickness="2" Padding="10,5" Background="Transparent" PointerPressed="Channel_PointerPressed">
                <Border.Styles>
                  <Style Selector="Border">
                    <Setter Property="BorderBrush" Value="#404040"/>
                  </Style>
                  <Style Selector="Border.active">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                  </Style>
                </Border.Styles>
                <StackPanel>
                  <CheckBox Content="{Binding Name}" IsChecked="{Binding IsVisible}"/>

                  <Grid Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="V/div:" Grid.Row="0" Grid.Column="0"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <local:UnitNumericUpDown Grid.Row="0" Grid.Column="1" Width="300" HorizontalAlignment="Left" Margin="0,5,0,0"
                                             BaseValue="{Binding Scale}" UnitSymbol="V"/>


                    <TextBlock Text="V Offset:" Grid.Row="1" Grid.Column="0"
                               VerticalAlignment="Center" Margin="0,5,10,0"/>
                    <local:UnitNumericUpDown Grid.Row="1" Grid.Column="1" Width="300" HorizontalAlignment="Left" Margin="0,5,0,0"
                                             IncrementType="Step" Step="{Binding Scale}"
                                             BaseValue="{Binding VoltageOffset}" UnitSymbol="V"/>


                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </DockPanel>
</Window>
